# ─────────────────────────────────────────────────────────────────────────────
# Allyvate Brain — Phase 1 environment template.
# Copy to `.env` (gitignored). In prod these load from AWS Secrets Manager + KMS.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Storage: one Postgres instance (Neon) does five jobs (ADR 0001) ───────────
# pgvector + tsvector/pg_trgm + typed-edge tables + outcome weights + KO metadata.
# Real values go in .env.local (gitignored). Neon dev branch from Week 3 (ADR 0003):
#   DATABASE_URL        = POOLED (-pooler) endpoint — runtime / eval / retrieval
#   DATABASE_URL_DIRECT = DIRECT (unpooled) endpoint — migrations / seeds
# createDb disables prepared statements automatically on a pooled URL.
# Local dev example: postgresql://user@localhost:5432/allyvate?sslmode=disable
DATABASE_URL=
DATABASE_URL_DIRECT=

# ── Redis (live session memory + BullMQ) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM: Anthropic Claude Sonnet (ingestion classifier + turn brain) ──────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Embeddings: OpenAI text + Whisper batch transcription ─────────────────────
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-large

# ── Reranker: Cohere Rerank (provider-abstracted) ────────────────────────────
COHERE_API_KEY=

# ── Document extraction: LlamaParse ──────────────────────────────────────────
LLAMA_CLOUD_API_KEY=

# ── Auth / multi-tenant boundary: Clerk + Google OAuth ───────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ── MCP connectors (read-only this phase) ────────────────────────────────────
# Confluence, Google Drive (ingestion); HubSpot, Salesforce (CRM, read-only)
CONFLUENCE_MCP_URL=
GDRIVE_MCP_URL=
HUBSPOT_MCP_URL=
SALESFORCE_MCP_URL=

# ── Object storage (raw vault, Brand Books, thumbnails) ──────────────────────
S3_BUCKET=
AWS_REGION=us-east-1

# ── API server ───────────────────────────────────────────────────────────────
BRAIN_API_PORT=4000

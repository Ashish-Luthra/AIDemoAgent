{
  "name": "allyvate-brain",
  "version": "0.0.0",
  "private": true,
  "description": "Allyvate Organisation Brain + Intelligence Layer (Phase 1, headless)",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml,yml}\"",
    "db:generate": "pnpm --filter @allyvate/db db:generate",
    "db:migrate": "pnpm --filter @allyvate/db db:migrate",
    "db:seed": "pnpm --filter @allyvate/db db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  }
}
